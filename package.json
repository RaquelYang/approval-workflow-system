{
    "name": "approval-workflow-system",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "prestart": "npm run lint:all",
        "start": "ng serve",
        "prebuild": "npm run lint:all",
        "build": "ng build",
        "api": "json-server --watch db.json --port 3000",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --watch=false",
        "lint": "ng lint",
        "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
        "lint:all": "npm run lint && npm run lint:styles",
        "format": "prettier --write \"*.json\" \"*.js\" \".prettierrc\" \".postcssrc.json\" \".stylelintrc.json\" \".vscode/**/*.json\" \"README.md\" \"src/**/*.{ts,html,scss,css}\" \"tsconfig*.json\"",
        "format:check": "prettier --check \"*.json\" \"*.js\" \".prettierrc\" \".postcssrc.json\" \".stylelintrc.json\" \".vscode/**/*.json\" \"README.md\" \"src/**/*.{ts,html,scss,css}\" \"tsconfig*.json\""
    },
    "private": true,
    "packageManager": "npm@10.9.4",
    "dependencies": {
        "@angular/cdk": "^21.2.9",
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/material": "^21.2.9",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.0",
        "@angular/cli": "^21.2.0",
        "@angular/compiler-cli": "^21.2.0",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.2.4",
        "angular-eslint": "21.3.1",
        "eslint": "^10.0.3",
        "jsdom": "^28.0.0",
        "json-server": "^0.17.4",
        "postcss": "^8.5.12",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "speckit": "^0.1.0",
        "stylelint": "^17.9.1",
        "stylelint-config-prettier-scss": "^1.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "tailwindcss": "^4.2.4",
        "typescript": "~5.9.2",
        "typescript-eslint": "8.56.1",
        "vitest": "^4.0.8"
    }
}
