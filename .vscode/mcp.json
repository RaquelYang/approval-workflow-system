{
    // For more information, visit: https://angular.dev/ai/mcp
    "servers": {
        "angular-cli": {
            "command": "npx",
            "args": [
                "-y",
                "@angular/cli",
                "mcp"
            ]
        },
        "stitch": {
            "type": "http",
            "url": "https://stitch.googleapis.com/mcp",
            "headers": {
                "Accept": "application/json",
                "X-Goog-Api-Key": "${env:STITCH_API_KEY}"
            }
        }
    }
}
